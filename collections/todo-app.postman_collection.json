{
  "info": {
    "_postman_id": "66ff1d6e-5dd8-4593-8b99-ac7ff6293e7f",
    "name": "Todo App API",
    "description": "Complete collection for the Todo App API built with FastAPI. Includes CRUD operations for todos with Basic Auth.\n\n**Getting started:**\n1. Import the `local.postman_environment.json` environment\n2. Select the `Todo App - Local` environment\n3. Run `Create Todo` — the ID is automatically saved to a variable\n4. Other requests will use the ID automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "54930360"
  },
  "item": [
    {
      "name": "Todos",
      "item": [
        {
          "name": "Get All Todos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each todo has id, title and completed', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function (todo) {",
                  "        pm.expect(todo).to.have.property('id');",
                  "        pm.expect(todo).to.have.property('title');",
                  "        pm.expect(todo).to.have.property('completed');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Pagination pattern — saves cursor for the next page if the API supports pagination.",
                  "// Current API does not support pagination, script is ready for future use.",
                  "const body = pm.response.json();",
                  "const cursor = body.next_cursor || body.next || null;",
                  "if (cursor) {",
                  "    pm.collectionVariables.set('next_cursor', cursor);",
                  "    console.log('Next page available, cursor:', cursor);",
                  "} else {",
                  "    pm.collectionVariables.unset('next_cursor');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}{{host}}{{port}}/todos",
              "host": [
                "{{protocol}}{{host}}{{port}}"
              ],
              "path": [
                "todos"
              ]
            },
            "description": "Returns a list of all todos. If the API returns a pagination cursor, it is automatically saved to `next_cursor`."
          },
          "response": []
        },
        {
          "name": "Get Next Page",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('next_cursor')) {",
                  "    throw new Error('next_cursor is not set — run Get All Todos first');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const cursor = body.next_cursor || body.next || null;",
                  "if (cursor) {",
                  "    pm.collectionVariables.set('next_cursor', cursor);",
                  "} else {",
                  "    pm.collectionVariables.unset('next_cursor');",
                  "    console.log('Last page of results');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}{{host}}{{port}}/todos?cursor={{next_cursor}}",
              "host": [
                "{{protocol}}{{host}}{{port}}"
              ],
              "path": [
                "todos"
              ],
              "query": [
                {
                  "key": "cursor",
                  "value": "{{next_cursor}}"
                }
              ]
            },
            "description": "Loads the next page of results using the cursor from the previous call.\n\n> Pagination template — the current API does not support pagination. Run after `Get All Todos` when `next_cursor` is not empty."
          },
          "response": []
        },
        {
          "name": "Create Todo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains the id of the new todo', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    // Saves ID for Get Todo by ID, Update Todo and Delete Todo",
                  "    pm.collectionVariables.set('todo_id', body.id);",
                  "    console.log('Todo created with ID:', body.id);",
                  "});",
                  "",
                  "pm.test('Todo has the correct title', function () {",
                  "    const requestBody = JSON.parse(pm.request.body.raw);",
                  "    const responseBody = pm.response.json();",
                  "    pm.expect(responseBody.title).to.equal(requestBody.title);",
                  "});",
                  "",
                  "pm.test('Todo is created as incomplete', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.completed).to.be.false;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{$randomLoremWords}}\",\n  \"description\": \"Created via Postman collection\",\n  \"completed\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{protocol}}{{host}}{{port}}/todos",
              "host": [
                "{{protocol}}{{host}}{{port}}"
              ],
              "path": [
                "todos"
              ]
            },
            "description": "Creates a new todo. The ID is automatically saved to the `todo_id` collection variable, which is then used by Get, Update and Delete."
          },
          "response": []
        },
        {
          "name": "Get Todo by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('todo_id')) {",
                  "    throw new Error('todo_id is not set — run Create Todo first');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returned ID matches the requested one', function () {",
                  "    const body = pm.response.json();",
                  "    const expectedId = parseInt(pm.collectionVariables.get('todo_id'));",
                  "    pm.expect(body.id).to.equal(expectedId);",
                  "});",
                  "",
                  "pm.test('Todo has all required fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.all.keys('id', 'title', 'completed');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}{{host}}{{port}}/todos/{{todo_id}}",
              "host": [
                "{{protocol}}{{host}}{{port}}"
              ],
              "path": [
                "todos",
                "{{todo_id}}"
              ]
            },
            "description": "Returns the detail of a specific todo. Uses `todo_id` saved after Create Todo."
          },
          "response": []
        },
        {
          "name": "Update Todo",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('todo_id')) {",
                  "    throw new Error('todo_id is not set — run Create Todo first');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Todo is now marked as completed', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.completed).to.be.true;",
                  "});",
                  "",
                  "pm.test('ID has not changed', function () {",
                  "    const body = pm.response.json();",
                  "    const expectedId = parseInt(pm.collectionVariables.get('todo_id'));",
                  "    pm.expect(body.id).to.equal(expectedId);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completed\": true,\n  \"description\": \"Updated via Postman\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{protocol}}{{host}}{{port}}/todos/{{todo_id}}",
              "host": [
                "{{protocol}}{{host}}{{port}}"
              ],
              "path": [
                "todos",
                "{{todo_id}}"
              ]
            },
            "description": "Updates an existing todo. Fields are optional — only send the ones you want to change."
          },
          "response": []
        },
        {
          "name": "Delete Todo",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('todo_id')) {",
                  "    throw new Error('todo_id is not set — run Create Todo first');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "pm.test('Response body is empty', function () {",
                  "    pm.expect(pm.response.text()).to.be.empty;",
                  "});",
                  "",
                  "pm.collectionVariables.unset('todo_id');"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{protocol}}{{host}}{{port}}/todos/{{todo_id}}",
              "host": [
                "{{protocol}}{{host}}{{port}}"
              ],
              "path": [
                "todos",
                "{{todo_id}}"
              ]
            },
            "description": "Deletes a todo by ID. Returns 204 with no response body."
          },
          "response": []
        }
      ],
      "description": "CRUD operations for managing todos"
    },
